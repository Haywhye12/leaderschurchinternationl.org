<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} ^(www\.)?leaderschurchinternational\.org [NC]
RewriteRule ^(.*)$ https://leaderschurchinternational.org/$1 [L,R=301]
</IfModule>
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{HTTP_HOST} ^(www\.)?leaderschurchinternational\.org [NC]
RewriteRule .* - [E=UPGRADE]
    <IfModule mod_headers.c>
        Header always set Content-Security-Policy "upgrade-insecure-requests;" env=UPGRADE
    </IfModule>
</IfModule>
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} ^(www\.)?leaderschurchinternational\.org$ [NC]
RewriteRule ^(.*)$ https://leaderschurchinternational.org/$1 [L,R=301]
</IfModule>

<ifModule mod_headers.c> 
 Header always set Content-Security-Policy "upgrade-insecure-requests;" 
</IfModule>


RewriteEngine On 
RewriteCond %{SERVER_PORT} 80
RewriteCond %{HTTP_HOST} ^(www\.)?leaderschurchinternational\.org
RewriteRule ^(.*)$ https://www.leaderschurchinternational.org/$1 [R,L]